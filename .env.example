# Copy to .env and adjust. The server also boots with built-in defaults.

# ── HTTP server ──
PORT=3003

# ── ClickHouse connection ──
CLICKHOUSE_URL=http://host.docker.internal:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_MAX_EXECUTION_TIME=30

# ── Logs table (OpenTelemetry logs schema) ──
LOGS_TABLE=otel_logs

# ── Column overrides (only set these if your table uses different names) ──
# COL_TIMESTAMP=Timestamp
# COL_SEVERITY_TEXT=SeverityText
# COL_SEVERITY_NUMBER=SeverityNumber
# COL_BODY=Body
# COL_SERVICE_NAME=ServiceName
# COL_TRACE_ID=TraceId
# COL_SPAN_ID=SpanId
# COL_RESOURCE_ATTRIBUTES=ResourceAttributes
# COL_LOG_ATTRIBUTES=LogAttributes
